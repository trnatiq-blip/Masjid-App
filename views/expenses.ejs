<!DOCTYPE html>
<html lang="en">
<%- include('partials/head') %>
<body class="min-h-screen bg-slate-900">
  <%- include('partials/sidebar') %>
  
  <div class="lg:pl-64 min-h-screen">
    <header class="glass sticky top-0 z-30 border-b border-white/10">
      <div class="flex items-center justify-between px-4 py-4">
        <div class="flex items-center">
          <button onclick="toggleSidebar()" class="lg:hidden mr-4 text-slate-300 hover:text-white">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
          </button>
          <h1 class="text-2xl font-bold text-white">Expenses</h1>
        </div>
        <% if (canEdit) { %>
        <button onclick="document.getElementById('add-form').classList.toggle('hidden')" class="bg-gradient-to-r from-emerald-500 to-emerald-600 hover:from-emerald-600 hover:to-emerald-700 text-white px-4 py-2 rounded-lg font-medium transition-all flex items-center shadow-lg shadow-emerald-500/25">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
          Add Expense
        </button>
        <% } %>
      </div>
    </header>
    
    <main class="p-4 lg:p-6">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-6">
        <div class="glass-card rounded-xl p-5 border border-white/10 card-hover animate-slide-up">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-slate-400 text-sm">Total Expenses</p>
              <p class="text-2xl font-bold text-red-400 mt-1">$<%= Number(total).toLocaleString() %></p>
            </div>
            <div class="w-12 h-12 rounded-xl bg-red-500/20 flex items-center justify-center border border-red-500/30">
              <svg class="w-6 h-6 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
            </div>
          </div>
        </div>
      </div>
      
      <% if (canEdit) { %>
      <div id="add-form" class="hidden glass-card rounded-xl p-6 mb-6 border border-white/10 animate-slide-up">
        <h3 class="text-lg font-semibold text-white mb-4 flex items-center">
          <svg class="w-5 h-5 mr-2 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
          Add New Expense
        </h3>
        <form action="/expenses" method="POST" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
          <div>
            <input type="text" name="category" required placeholder="Category (e.g., Utilities, Repairs)" class="w-full rounded-lg px-4 py-3 bg-slate-800/50 border border-white/10 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-emerald-500">
          </div>
          <div>
            <input type="number" name="amount" required min="0" step="0.01" placeholder="Amount" class="w-full rounded-lg px-4 py-3 bg-slate-800/50 border border-white/10 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-emerald-500">
          </div>
          <div>
            <input type="date" name="expense_date" required class="w-full rounded-lg px-4 py-3 bg-slate-800/50 border border-white/10 text-white focus:outline-none focus:ring-2 focus:ring-emerald-500">
          </div>
          <div>
            <select name="status" class="w-full rounded-lg px-4 py-3 bg-slate-800/50 border border-white/10 text-white focus:outline-none focus:ring-2 focus:ring-emerald-500">
              <option value="pending">Pending</option>
              <option value="paid">Paid</option>
            </select>
          </div>
          <div class="md:col-span-2 lg:col-span-4">
            <textarea name="description" placeholder="Description (optional)" rows="2" class="w-full rounded-lg px-4 py-3 bg-slate-800/50 border border-white/10 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-emerald-500"></textarea>
          </div>
          <div class="md:col-span-4 flex space-x-4">
            <button type="submit" class="bg-gradient-to-r from-emerald-500 to-emerald-600 hover:from-emerald-600 hover:to-emerald-700 text-white px-6 py-2 rounded-lg font-medium transition-all">Add Expense</button>
            <button type="button" onclick="document.getElementById('add-form').classList.add('hidden')" class="bg-slate-700 hover:bg-slate-600 text-slate-300 px-6 py-2 rounded-lg font-medium transition-colors">Cancel</button>
          </div>
        </form>
      </div>
      <% } %>
      
      <div class="glass-card rounded-xl overflow-hidden border border-white/10 animate-slide-up">
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead class="bg-slate-800/50">
              <tr>
                <th class="px-6 py-4 text-left text-sm font-semibold text-slate-300">Category</th>
                <th class="px-6 py-4 text-left text-sm font-semibold text-slate-300">Amount</th>
                <th class="px-6 py-4 text-left text-sm font-semibold text-slate-300">Date</th>
                <th class="px-6 py-4 text-left text-sm font-semibold text-slate-300">Status</th>
                <th class="px-6 py-4 text-left text-sm font-semibold text-slate-300">Description</th>
                <% if (canEdit) { %>
                <th class="px-6 py-4 text-left text-sm font-semibold text-slate-300">Actions</th>
                <% } %>
              </tr>
            </thead>
            <tbody class="divide-y divide-white/10">
              <% expenses.forEach(e => { %>
                <tr class="hover:bg-slate-800/30 transition-colors">
                  <td class="px-6 py-4 text-white font-medium"><%= e.category %></td>
                  <td class="px-6 py-4 text-red-400 font-semibold">$<%= Number(e.amount).toLocaleString() %></td>
                  <td class="px-6 py-4 text-slate-400 text-sm"><%= new Date(e.expense_date).toLocaleDateString() %></td>
                  <td class="px-6 py-4">
                    <span class="<%= e.status === 'paid' ? 'bg-emerald-500/20 text-emerald-400 border-emerald-500/30' : 'bg-amber-500/20 text-amber-400 border-amber-500/30' %> px-2 py-1 rounded text-xs font-medium capitalize border"><%= e.status %></span>
                  </td>
                  <td class="px-6 py-4 text-slate-400 text-sm"><%= e.description || '-' %></td>
                  <% if (canEdit) { %>
                  <td class="px-6 py-4">
                    <div class="flex gap-2">
                      <button type="button" onclick="document.getElementById('edit-form-<%= e.id %>').classList.toggle('hidden')" class="bg-blue-500/20 hover:bg-blue-500/30 text-blue-400 px-3 py-1 rounded text-xs font-medium transition-colors border border-blue-500/30">Edit</button>
                      <form action="/expenses/<%= e.id %>/delete" method="POST" onsubmit="return confirm('Delete this expense?');">
                        <button type="submit" class="bg-red-500/20 hover:bg-red-500/30 text-red-400 px-3 py-1 rounded text-xs font-medium transition-colors border border-red-500/30">Delete</button>
                      </form>
                    </div>
                  </td>
                  <% } %>
                </tr>
                <tr id="edit-form-<%= e.id %>" class="hidden bg-slate-800/30">
                  <td colspan="6" class="px-6 py-4">
                    <form action="/expenses/<%= e.id %>/update" method="POST" class="space-y-3">
                      <div class="grid grid-cols-1 md:grid-cols-5 gap-3">
                        <div>
                          <label class="block text-xs text-slate-400 mb-1">Category</label>
                          <input type="text" name="category" value="<%= e.category %>" required class="w-full rounded px-3 py-2 text-sm bg-slate-800/50 border border-white/10 text-white">
                        </div>
                        <div>
                          <label class="block text-xs text-slate-400 mb-1">Amount</label>
                          <input type="number" name="amount" value="<%= e.amount %>" required min="0" step="0.01" class="w-full rounded px-3 py-2 text-sm bg-slate-800/50 border border-white/10 text-white">
                        </div>
                        <div>
                          <label class="block text-xs text-slate-400 mb-1">Date</label>
                          <input type="date" name="expense_date" value="<%= e.expense_date %>" required class="w-full rounded px-3 py-2 text-sm bg-slate-800/50 border border-white/10 text-white">
                        </div>
                        <div>
                          <label class="block text-xs text-slate-400 mb-1">Status</label>
                          <select name="status" class="w-full rounded px-3 py-2 text-sm bg-slate-800/50 border border-white/10 text-white">
                            <option value="pending" <%= e.status === 'pending' ? 'selected' : '' %>>Pending</option>
                            <option value="paid" <%= e.status === 'paid' ? 'selected' : '' %>>Paid</option>
                          </select>
                        </div>
                        <div>
                          <label class="block text-xs text-slate-400 mb-1">Description</label>
                          <input type="text" name="description" value="<%= e.description || '' %>" placeholder="Description" class="w-full rounded px-3 py-2 text-sm bg-slate-800/50 border border-white/10 text-white placeholder-slate-500">
                        </div>
                      </div>
                      <div class="flex gap-2">
                        <button type="submit" class="bg-gradient-to-r from-emerald-500 to-emerald-600 hover:from-emerald-600 hover:to-emerald-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-all">Save Changes</button>
                        <button type="button" onclick="document.getElementById('edit-form-<%= e.id %>').classList.add('hidden')" class="bg-slate-700 hover:bg-slate-600 text-slate-300 px-4 py-2 rounded-lg text-sm font-medium transition-colors">Cancel</button>
                      </div>
                    </form>
                  </td>
                </tr>
              <% }) %>
              <% if (expenses.length === 0) { %>
                <tr>
                  <td colspan="<%= canEdit ? 6 : 5 %>" class="px-6 py-8 text-center text-slate-500">No expenses recorded yet.</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>
</body>
</html>