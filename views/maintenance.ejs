<!DOCTYPE html>
<html lang="en">
<%- include('partials/head') %>
<body class="min-h-screen bg-slate-900">
  <%- include('partials/sidebar') %>
  
  <div class="lg:pl-64 min-h-screen">
    <header class="glass sticky top-0 z-30 border-b border-white/10">
      <div class="flex items-center justify-between px-4 py-4">
        <div class="flex items-center">
          <button onclick="toggleSidebar()" class="lg:hidden mr-4 text-slate-300 hover:text-white">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
          </button>
          <h1 class="text-2xl font-bold text-white">Maintenance Tasks</h1>
        </div>
        <% if (canEdit) { %>
        <button onclick="document.getElementById('add-form').classList.toggle('hidden')" class="bg-gradient-to-r from-emerald-500 to-emerald-600 hover:from-emerald-600 hover:to-emerald-700 text-white px-4 py-2 rounded-lg font-medium transition-all flex items-center shadow-lg shadow-emerald-500/25">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
          New Task
        </button>
        <% } %>
      </div>
    </header>
    
    <main class="p-4 lg:p-6">
      <% if (canEdit) { %>
      <div id="add-form" class="hidden glass-card rounded-xl p-6 mb-6 border border-white/10 animate-slide-up">
        <h3 class="text-lg font-semibold text-white mb-4 flex items-center">
          <svg class="w-5 h-5 mr-2 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          Create Task
        </h3>
        <form action="/maintenance" method="POST" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          <div>
            <input type="text" name="title" required placeholder="Title" class="w-full rounded-lg px-4 py-3 bg-slate-800/50 border border-white/10 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-emerald-500">
          </div>
          <div>
            <input type="text" name="location" placeholder="Location" class="w-full rounded-lg px-4 py-3 bg-slate-800/50 border border-white/10 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-emerald-500">
          </div>
          <div>
            <select name="priority" class="w-full rounded-lg px-4 py-3 bg-slate-800/50 border border-white/10 text-white focus:outline-none focus:ring-2 focus:ring-emerald-500">
              <option value="low">Low</option>
              <option value="medium" selected>Medium</option>
              <option value="high">High</option>
              <option value="urgent">Urgent</option>
            </select>
          </div>
          <div>
            <select name="status" class="w-full rounded-lg px-4 py-3 bg-slate-800/50 border border-white/10 text-white focus:outline-none focus:ring-2 focus:ring-emerald-500">
              <option value="pending" selected>Pending</option>
              <option value="in_progress">In Progress</option>
              <option value="completed">Completed</option>
            </select>
          </div>
          <div>
            <select name="assigned_to" class="w-full rounded-lg px-4 py-3 bg-slate-800/50 border border-white/10 text-white focus:outline-none focus:ring-2 focus:ring-emerald-500">
              <option value="">Unassigned</option>
              <% users.forEach(u => { %>
                <option value="<%= u.id %>"><%= u.name %></option>
              <% }) %>
            </select>
          </div>
          <div class="md:col-span-2 lg:col-span-3">
            <textarea name="description" placeholder="Description" rows="2" class="w-full rounded-lg px-4 py-3 bg-slate-800/50 border border-white/10 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-emerald-500"></textarea>
          </div>
          <div class="md:col-span-3 flex space-x-4">
            <button type="submit" class="bg-gradient-to-r from-emerald-500 to-emerald-600 hover:from-emerald-600 hover:to-emerald-700 text-white px-6 py-2 rounded-lg font-medium transition-all">Create</button>
            <button type="button" onclick="document.getElementById('add-form').classList.add('hidden')" class="bg-slate-700 hover:bg-slate-600 text-slate-300 px-6 py-2 rounded-lg font-medium transition-colors">Cancel</button>
          </div>
        </form>
      </div>
      <% } %>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <% tasks.forEach((t, i) => { %>
          <div class="glass-card rounded-xl p-5 border border-white/10 card-hover animate-slide-up" style="animation-delay: <%= i * 0.05 %>s">
            <div class="flex justify-between items-start mb-3">
              <div class="flex items-center">
                <div class="w-10 h-10 rounded-lg bg-amber-500/20 flex items-center justify-center mr-3 border border-amber-500/30">
                  <svg class="w-5 h-5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/></svg>
                </div>
                <h3 class="text-lg font-semibold text-white"><%= t.title %></h3>
              </div>
              <% if (canEdit) { %>
              <form action="/maintenance/<%= t.id %>/delete" method="POST" onsubmit="return confirm('Delete?');">
                <button type="submit" class="bg-red-500/20 hover:bg-red-500/30 text-red-400 px-2 py-1 rounded text-xs font-medium transition-colors border border-red-500/30">X</button>
              </form>
              <% } %>
            </div>
            <p class="text-slate-400 text-sm"><%= t.description || 'No description' %></p>
            <div class="flex flex-wrap gap-2 mt-3">
              <span class="px-2 py-1 rounded text-xs font-medium <%= t.priority === 'urgent' ? 'bg-red-500/20 text-red-400' : t.priority === 'high' ? 'bg-amber-500/20 text-amber-400' : 'bg-slate-700 text-slate-300' %> capitalize border <%= t.priority === 'urgent' ? 'border-red-500/30' : t.priority === 'high' ? 'border-amber-500/30' : 'border-slate-600' %>"><%= t.priority %></span>
              <span class="px-2 py-1 rounded text-xs font-medium <%= t.status === 'completed' ? 'bg-emerald-500/20 text-emerald-400' : t.status === 'in_progress' ? 'bg-blue-500/20 text-blue-400' : 'bg-amber-500/20 text-amber-400' %> capitalize border <%= t.status === 'completed' ? 'border-emerald-500/30' : t.status === 'in_progress' ? 'border-blue-500/30' : 'border-amber-500/30' %>"><%= t.status.replace('_', ' ') %></span>
            </div>
            <div class="mt-3 text-xs text-slate-500">
              <p class="flex items-center"><svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg><%= t.location || 'N/A' %></p>
              <p class="flex items-center mt-1"><svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg><%= t.assigned_name || 'Unassigned' %></p>
            </div>
            <% if (canEdit) { %>
            <form action="/maintenance/<%= t.id %>/update" method="POST" class="mt-4 pt-4 border-t border-white/10">
              <button type="button" onclick="document.getElementById('update-form-<%= t.id %>').classList.toggle('hidden')" class="w-full bg-emerald-500/10 hover:bg-emerald-500/20 text-emerald-400 py-1 rounded text-xs font-medium transition-colors">Update</button>
              <div id="update-form-<%= t.id %>" class="hidden mt-2 space-y-2">
                <div class="grid grid-cols-2 gap-2">
                  <select name="status" class="bg-slate-800/50 border border-white/10 text-slate-300 text-xs rounded px-2 py-1 focus:outline-none focus:ring-2 focus:ring-emerald-500">
                    <% ['pending', 'in_progress', 'completed'].forEach(s => { %>
                      <option value="<%= s %>" <%= t.status === s ? 'selected' : '' %> class="capitalize"><%= s.replace('_', ' ') %></option>
                    <% }) %>
                  </select>
                  <select name="assigned_to" class="bg-slate-800/50 border border-white/10 text-slate-300 text-xs rounded px-2 py-1 focus:outline-none focus:ring-2 focus:ring-emerald-500">
                    <option value="">Unassigned</option>
                    <% users.forEach(u => { %>
                      <option value="<%= u.id %>" <%= t.assigned_to === u.id ? 'selected' : '' %>><%= u.name %></option>
                    <% }) %>
                  </select>
                </div>
                <button type="submit" class="w-full bg-gradient-to-r from-emerald-500 to-emerald-600 hover:from-emerald-600 hover:to-emerald-700 text-white py-1 rounded text-xs font-medium transition-all">Save</button>
              </div>
            </form>
            <% } %>
          </div>
        <% }) %>
        <% if (tasks.length === 0) { %>
          <div class="md:col-span-3 glass-card rounded-xl p-8 text-center border border-white/10">
            <svg class="w-12 h-12 mx-auto text-slate-600 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/></svg>
            <p class="text-slate-400">No maintenance tasks yet.</p>
          </div>
        <% } %>
      </div>
    </main>
  </div>
</body>
</html>