<!DOCTYPE html>
<html lang="en">
<%- include('partials/head') %>
<body class="min-h-screen bg-slate-900">
  <%- include('partials/sidebar') %>
  
  <div class="lg:pl-64 min-h-screen">
    <header class="glass sticky top-0 z-30 border-b border-white/10">
      <div class="flex items-center justify-between px-4 py-4">
        <div class="flex items-center">
          <button onclick="toggleSidebar()" class="lg:hidden mr-4 text-slate-300 hover:text-white">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
          </button>
          <h1 class="text-2xl font-bold text-white">Finances</h1>
        </div>
        <% if (canEdit) { %>
        <button onclick="document.getElementById('add-form').classList.toggle('hidden')" class="bg-gradient-to-r from-emerald-500 to-emerald-600 hover:from-emerald-600 hover:to-emerald-700 text-white px-4 py-2 rounded-lg font-medium transition-all flex items-center shadow-lg shadow-emerald-500/25">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
          Record Transaction
        </button>
        <% } %>
      </div>
    </header>
    
    <main class="p-4 lg:p-6">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-6">
        <div class="glass-card rounded-xl p-5 text-white border border-white/10 card-hover animate-slide-up">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-slate-400 text-sm">Total Donations</p>
              <p class="text-2xl font-bold mt-1 text-emerald-400">$<%= Number(totals.donation).toLocaleString() %></p>
            </div>
            <div class="w-12 h-12 rounded-xl bg-emerald-500/20 flex items-center justify-center border border-emerald-500/30">
              <svg class="w-6 h-6 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
          </div>
        </div>
        <div class="glass-card rounded-xl p-5 text-white border border-white/10 card-hover animate-slide-up" style="animation-delay: 0.05s">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-slate-400 text-sm">Total Expenses</p>
              <p class="text-2xl font-bold text-red-400 mt-1">$<%= Number(totals.expense).toLocaleString() %></p>
            </div>
            <div class="w-12 h-12 rounded-xl bg-red-500/20 flex items-center justify-center border border-red-500/30">
              <svg class="w-6 h-6 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
            </div>
          </div>
        </div>
        <div class="glass-card rounded-xl p-5 text-white border border-white/10 card-hover animate-slide-up" style="animation-delay: 0.1s">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-slate-400 text-sm">Net Balance</p>
              <p class="text-2xl font-bold mt-1 <%= totals.donation - totals.expense >= 0 ? 'text-emerald-400' : 'text-red-400' %>">$<%= Number(totals.donation - totals.expense).toLocaleString() %></p>
            </div>
            <div class="w-12 h-12 rounded-xl bg-amber-500/20 flex items-center justify-center border border-amber-500/30">
              <svg class="w-6 h-6 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
            </div>
          </div>
        </div>
      </div>
      
      <% if (canEdit) { %>
      <div id="add-form" class="hidden glass-card rounded-xl p-6 mb-6 border border-white/10 animate-slide-up">
        <h3 class="text-lg font-semibold text-white mb-4 flex items-center">
          <svg class="w-5 h-5 mr-2 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Record Transaction
        </h3>
        <form action="/finances" method="POST" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
          <div>
            <select name="type" required class="w-full rounded-lg px-4 py-3 bg-slate-800/50 border border-white/10 text-white focus:outline-none focus:ring-2 focus:ring-emerald-500">
              <option value="donation">Donation</option>
              <option value="expense">Expense</option>
            </select>
          </div>
          <div>
            <input type="text" name="category" required placeholder="Category (e.g., Zakat, Utilities)" class="w-full rounded-lg px-4 py-3 bg-slate-800/50 border border-white/10 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-emerald-500">
          </div>
          <div>
            <input type="number" name="amount" required min="0" step="0.01" placeholder="Amount" class="w-full rounded-lg px-4 py-3 bg-slate-800/50 border border-white/10 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-emerald-500">
          </div>
          <div>
            <input type="date" name="transaction_date" required class="w-full rounded-lg px-4 py-3 bg-slate-800/50 border border-white/10 text-white focus:outline-none focus:ring-2 focus:ring-emerald-500">
          </div>
          <div class="md:col-span-2 lg:col-span-4">
            <textarea name="description" placeholder="Description (optional)" rows="2" class="w-full rounded-lg px-4 py-3 bg-slate-800/50 border border-white/10 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-emerald-500"></textarea>
          </div>
          <div class="md:col-span-4 flex space-x-4">
            <button type="submit" class="bg-gradient-to-r from-emerald-500 to-emerald-600 hover:from-emerald-600 hover:to-emerald-700 text-white px-6 py-2 rounded-lg font-medium transition-all">Record</button>
            <button type="button" onclick="document.getElementById('add-form').classList.add('hidden')" class="bg-slate-700 hover:bg-slate-600 text-slate-300 px-6 py-2 rounded-lg font-medium transition-colors">Cancel</button>
          </div>
        </form>
      </div>
      <% } %>
      
      <div class="glass-card rounded-xl overflow-hidden border border-white/10 animate-slide-up">
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead class="bg-slate-800/50">
              <tr>
                <th class="px-6 py-4 text-left text-sm font-semibold text-slate-300">Type</th>
                <th class="px-6 py-4 text-left text-sm font-semibold text-slate-300">Category</th>
                <th class="px-6 py-4 text-left text-sm font-semibold text-slate-300">Amount</th>
                <th class="px-6 py-4 text-left text-sm font-semibold text-slate-300">Date</th>
                <th class="px-6 py-4 text-left text-sm font-semibold text-slate-300">Description</th>
                <% if (canEdit) { %>
                <th class="px-6 py-4 text-left text-sm font-semibold text-slate-300">Actions</th>
                <% } %>
              </tr>
            </thead>
            <tbody class="divide-y divide-white/10">
              <% finances.forEach(function(f) { %>
              <tr class="hover:bg-slate-800/30 transition-colors">
                <td class="px-6 py-4">
                  <span class="<%= f.type === 'donation' ? 'bg-emerald-500/20 text-emerald-400' : 'bg-red-500/20 text-red-400' %> px-2 py-1 rounded text-xs font-medium capitalize border <%= f.type === 'donation' ? 'border-emerald-500/30' : 'border-red-500/30' %>"><%= f.type %></span>
                </td>
                <td class="px-6 py-4 text-slate-300"><%= f.category %></td>
                <td class="px-6 py-4 <%= f.type === 'donation' ? 'text-emerald-400' : 'text-red-400' %> font-semibold">$<%= Number(f.amount).toLocaleString() %></td>
                <td class="px-6 py-4 text-slate-400 text-sm"><%= new Date(f.transaction_date).toLocaleDateString() %></td>
                <td class="px-6 py-4 text-slate-400 text-sm"><%= f.description || '-' %></td>
                <% if (canEdit) { %>
                <td class="px-6 py-4">
                  <form action="/finances/<%= f.id %>/delete" method="POST" onsubmit="return confirm('Delete this transaction?');">
                    <button type="submit" class="bg-red-500/20 hover:bg-red-500/30 text-red-400 px-3 py-1 rounded text-xs font-medium transition-colors border border-red-500/30">Delete</button>
                  </form>
                </td>
                <% } %>
              </tr>
              <% }); %>
              <% if (finances.length === 0) { %>
              <tr>
                <td colspan="<%= canEdit ? 6 : 5 %>" class="px-6 py-8 text-center text-slate-500">No transactions recorded yet.</td>
              </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>
</body>
</html>