<!DOCTYPE html>
<html lang="en">
<%- include('partials/head') %>
<body class="min-h-screen bg-slate-900">
  <%- include('partials/sidebar') %>
  
  <div class="lg:pl-64 min-h-screen">
    <header class="glass sticky top-0 z-30 border-b border-white/10">
      <div class="flex items-center justify-between px-4 py-4">
        <div class="flex items-center">
          <button onclick="toggleSidebar()" class="lg:hidden mr-4 text-slate-300 hover:text-white">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
          </button>
          <h1 class="text-2xl font-bold text-white">User Management</h1>
        </div>
      <% if (role === 'admin') { %>
        <button onclick="document.getElementById('add-form').classList.toggle('hidden')" class="bg-gradient-to-r from-emerald-500 to-emerald-600 hover:from-emerald-600 hover:to-emerald-700 text-white px-4 py-2 rounded-lg font-medium transition-all flex items-center shadow-lg shadow-emerald-500/25">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
          Add User
        </button>
      <% } %>
      </div>
    </header>
    
    <main class="p-4 lg:p-6">
      
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4 mb-6">
        <div class="glass-card rounded-xl p-4 border border-white/10">
          <p class="text-slate-400 text-sm">Total Users</p>
          <p class="text-2xl font-bold text-white"><%= counts.total %></p>
        </div>
        <div class="glass-card rounded-xl p-4 border border-white/10">
          <p class="text-slate-400 text-sm">Imam</p>
          <p class="text-2xl font-bold text-purple-400"><%= counts.imam || 0 %></p>
        </div>
        <div class="glass-card rounded-xl p-4 border border-white/10">
          <p class="text-slate-400 text-sm">Khadim</p>
          <p class="text-2xl font-bold text-indigo-400"><%= counts.khadim || 0 %></p>
        </div>
        <div class="glass-card rounded-xl p-4 border border-white/10">
          <p class="text-slate-400 text-sm">Committee</p>
          <p class="text-2xl font-bold text-blue-400"><%= counts.committee %></p>
        </div>
        <div class="glass-card rounded-xl p-4 border border-white/10">
          <p class="text-slate-400 text-sm">Volunteers</p>
          <p class="text-2xl font-bold text-amber-400"><%= counts.volunteer %></p>
        </div>
        <div class="glass-card rounded-xl p-4 border border-white/10">
          <p class="text-slate-400 text-sm">Guests</p>
          <p class="text-2xl font-bold text-slate-300"><%= counts.guest || 0 %></p>
        </div>
      </div>
      
      <div id="add-form" class="hidden glass-card rounded-xl p-6 mb-6 border border-white/10 animate-slide-up">
        <h3 class="text-lg font-semibold text-white mb-4 flex items-center">
          <svg class="w-5 h-5 mr-2 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
          Add New User
        </h3>
        <form action="/admin/users" method="POST" class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <input type="text" name="name" required placeholder="Name" class="w-full rounded-lg px-4 py-3 bg-slate-800/50 border border-white/10 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-emerald-500">
          </div>
          <div>
            <input type="email" name="email" required placeholder="Email" class="w-full rounded-lg px-4 py-3 bg-slate-800/50 border border-white/10 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-emerald-500">
          </div>
          <div>
            <input type="password" name="password" placeholder="Password (default: password123)" class="w-full rounded-lg px-4 py-3 bg-slate-800/50 border border-white/10 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-emerald-500">
          </div>
            <div>
            <select name="role" class="w-full rounded-lg px-4 py-3 bg-slate-800/50 border border-white/10 text-white focus:outline-none focus:ring-2 focus:ring-emerald-500">
              <option value="imam">Imam</option>
              <option value="khadim">Khadim</option>
              <option value="committee">Committee</option>
              <option value="volunteer">Volunteer</option>
              <option value="guest">Guest</option>
            </select>
          </div>
          <div class="md:col-span-2 flex space-x-4">
            <button type="submit" class="bg-gradient-to-r from-emerald-500 to-emerald-600 hover:from-emerald-600 hover:to-emerald-700 text-white px-6 py-2 rounded-lg font-medium transition-all">Add User</button>
            <button type="button" onclick="document.getElementById('add-form').classList.add('hidden')" class="bg-slate-700 hover:bg-slate-600 text-slate-300 px-6 py-2 rounded-lg font-medium transition-colors">Cancel</button>
          </div>
        </form>
      </div>
      
      <div class="glass-card rounded-xl overflow-hidden border border-white/10 animate-slide-up">
        <div class="overflow-x-auto -mx-6 px-6">
          <table class="w-full min-w-[500px]">
            <thead class="bg-slate-800/50">
              <tr>
                <th class="px-6 py-4 text-left text-sm font-semibold text-slate-300">Name</th>
                <th class="px-6 py-4 text-left text-sm font-semibold text-slate-300">Email</th>
                <th class="px-6 py-4 text-left text-sm font-semibold text-slate-300">Role</th>
                <th class="px-6 py-4 text-left text-sm font-semibold text-slate-300">Joined</th>
                <th class="px-6 py-4 text-left text-sm font-semibold text-slate-300">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-white/10">
              <% users.forEach(u => { %>
                <tr class="hover:bg-slate-800/30 transition-colors">
                  <td class="px-6 py-4">
                    <div class="flex items-center">
                      <div class="w-10 h-10 rounded-full bg-emerald-500/20 flex items-center justify-center mr-3 border border-emerald-500/30">
                        <span class="text-emerald-400 font-semibold"><%= u.name.charAt(0).toUpperCase() %></span>
                      </div>
                      <span class="text-white font-medium"><%= u.name %></span>
                    </div>
                  </td>
                  <td class="px-6 py-4 text-slate-400"><%= u.email %></td>
                  <td class="px-6 py-4">
                    <span class="<%= 
                      u.role === 'admin' ? 'bg-emerald-500/20 text-emerald-400 border-emerald-500/30' : 
                      u.role === 'imam' ? 'bg-purple-500/20 text-purple-400 border-purple-500/30' :
                      u.role === 'khadim' ? 'bg-indigo-500/20 text-indigo-400 border-indigo-500/30' :
                      u.role === 'committee' ? 'bg-blue-500/20 text-blue-400 border-blue-500/30' :
                      u.role === 'volunteer' ? 'bg-amber-500/20 text-amber-400 border-amber-500/30' :
                      'bg-slate-700 text-slate-300 border-slate-600'
                    %> px-2 py-1 rounded-full text-xs font-medium capitalize border"><%= u.role %></span>
                  </td>
                  <td class="px-6 py-4 text-slate-400 text-sm"><%= new Date(u.created_at).toLocaleDateString() %></td>
                  <td class="px-6 py-4">
                    <div class="flex gap-2">
                      <button type="button" onclick="document.getElementById('edit-form-<%= u.id %>').classList.toggle('hidden')" class="bg-blue-500/20 hover:bg-blue-500/30 text-blue-400 px-3 py-1 rounded text-xs font-medium transition-colors border border-blue-500/30">Edit</button>
                      <% if (u.id !== 1 && u.id !== user.id) { %>
                        <form action="/admin/users/<%= u.id %>/delete" method="POST" onsubmit="return confirm('Delete this user?');">
                          <button type="submit" class="bg-red-500/20 hover:bg-red-500/30 text-red-400 px-3 py-1 rounded text-xs font-medium transition-colors border border-red-500/30">Delete</button>
                        </form>
                      <% } else { %>
                        <span class="text-slate-500 text-xs">Protected</span>
                      <% } %>
                    </div>
                  </td>
                </tr>
                <tr id="edit-form-<%= u.id %>" class="hidden bg-slate-800/30">
                  <td colspan="5" class="px-6 py-4">
                    <form action="/admin/users/<%= u.id %>/update" method="POST" class="grid grid-cols-1 md:grid-cols-4 gap-3 items-end">
                      <div>
                        <label class="text-xs text-slate-400">Name</label>
                        <input type="text" name="name" value="<%= u.name %>" required class="w-full rounded px-3 py-2 text-sm bg-slate-800/50 border border-white/10 text-white">
                      </div>
                      <div>
                        <label class="text-xs text-slate-400">New Password</label>
                        <input type="password" name="password" placeholder="Leave blank to keep" class="w-full rounded px-3 py-2 text-sm bg-slate-800/50 border border-white/10 text-white placeholder-slate-500">
                      </div>
                      <div>
                        <button type="submit" class="bg-gradient-to-r from-emerald-500 to-emerald-600 hover:from-emerald-600 hover:to-emerald-700 text-white px-4 py-2 rounded text-sm font-medium transition-all w-full">Save</button>
                      </div>
                      <div>
                        <button type="button" onclick="document.getElementById('edit-form-<%= u.id %>').classList.add('hidden')" class="bg-slate-700 hover:bg-slate-600 text-slate-300 px-4 py-2 rounded text-sm font-medium transition-colors w-full">Cancel</button>
                      </div>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>
</body>
</html>