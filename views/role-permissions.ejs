<!DOCTYPE html>
<html lang="en">
<%- include('partials/head') %>
<body class="min-h-screen bg-slate-900">
  <%- include('partials/sidebar') %>
  
  <div class="lg:pl-64 min-h-screen">
    <header class="glass sticky top-0 z-30 border-b border-white/10">
      <div class="flex items-center justify-between px-4 py-4">
        <div class="flex items-center">
          <button onclick="toggleSidebar()" class="lg:hidden mr-4 text-slate-300 hover:text-white">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
          </button>
          <h1 class="text-2xl font-bold text-white">Role Page Permissions</h1>
        </div>
      </div>
    </header>
    
    <main class="p-4 lg:p-6">
      <div class="glass-card rounded-xl p-6 border border-white/10">
        <p class="text-slate-400 mb-4">Click any toggle to change permission. Changes save automatically.</p>
        
        <div class="overflow-x-auto">
          <table class="w-full border border-white/10">
            <thead>
              <tr class="bg-slate-800/50">
                <th class="px-4 py-3 text-left text-sm font-semibold text-slate-300 border border-white/10 w-40">Page</th>
                <th class="px-2 py-3 text-center text-sm font-semibold text-purple-400 border border-white/10 bg-purple-500/10">Imam</th>
                <th class="px-2 py-3 text-center text-sm font-semibold text-indigo-400 border border-white/10 bg-indigo-500/10">Khadim</th>
                <th class="px-2 py-3 text-center text-sm font-semibold text-blue-400 border border-white/10 bg-blue-500/10">Committee</th>
                <th class="px-2 py-3 text-center text-sm font-semibold text-amber-400 border border-white/10 bg-amber-500/10">Volunteer</th>
                <th class="px-2 py-3 text-center text-sm font-semibold text-slate-400 border border-white/10 bg-slate-800/50">Guest</th>
              </tr>
            </thead>
            <tbody>
              <% 
              var pageList = [
                { id: 'prayer_times', name: 'Prayer Times' },
                { id: 'events', name: 'Events' },
                { id: 'announcements', name: 'Announcements' },
                { id: 'sermons', name: 'Sermons' },
                { id: 'meetings', name: 'Meetings' },
                { id: 'finances', name: 'Finances' },
                { id: 'expenses', name: 'Expenses' },
                { id: 'maintenance', name: 'Maintenance' },
                { id: 'users', name: 'Users' },
                { id: 'settings', name: 'Settings' }
              ];
              var roleList = ['imam', 'khadim', 'committee', 'volunteer', 'guest'];
              %>
              <% pageList.forEach(function(page) { %>
              <tr class="hover:bg-slate-800/30">
                <td class="px-4 py-3 text-sm font-medium text-white border border-white/10"><%= page.name %></td>
                <% roleList.forEach(function(role) { %>
                  <% var perm = allPermissions[role] && allPermissions[role][page.id] || { can_view: false, can_edit: false }; %>
                  <td class="px-2 py-3 text-center border border-white/10">
                    <div class="flex flex-col items-center gap-2">
                      <label class="relative inline-flex items-center cursor-pointer" title="View">
                        <input type="checkbox" class="sr-only peer" <%= perm.can_view ? 'checked' : '' %> onchange="toggle('<%= role %>', '<%= page.id %>', 'view', this.checked)">
                        <div class="w-9 h-5 bg-slate-700 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-emerald-500"></div>
                      </label>
                      <label class="relative inline-flex items-center cursor-pointer" title="Edit">
                        <input type="checkbox" class="sr-only peer" <%= perm.can_edit ? 'checked' : '' %> onchange="toggle('<%= role %>', '<%= page.id %>', 'edit', this.checked)">
                        <div class="w-9 h-5 bg-slate-700 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-amber-500"></div>
                      </label>
                    </div>
                  </td>
                <% }); %>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
        
        <div class="mt-4 text-sm text-slate-500">
          <span class="inline-flex items-center gap-1"><span class="w-6 h-5 bg-emerald-500 rounded-full"></span> View</span>
          <span class="inline-flex items-center gap-1 ml-4"><span class="w-6 h-5 bg-amber-500 rounded-full"></span> Edit</span>
        </div>
      </div>
    </main>
  </div>
  
  <div id="toast" class="fixed bottom-4 right-4 bg-emerald-500 text-white px-4 py-2 rounded-lg shadow-lg hidden"></div>
  
  <script>
    async function toggle(role, page, type, value) {
      try {
        const res = await fetch('/admin/role-pages/toggle', {
          method: 'POST',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ role, page, type })
        });
        const data = await res.json();
        if (data.success) {
          showToast('Saved!');
        }
      } catch(e) {
        alert('Error: ' + e.message);
      }
    }
    
    function showToast(msg) {
      const t = document.getElementById('toast');
      t.textContent = msg;
      t.classList.remove('hidden');
      setTimeout(() => t.classList.add('hidden'), 1000);
    }
    
    function toggleSidebar() {
      document.getElementById('sidebar').classList.toggle('-translate-x-full');
    }
  </script>
</body>
</html>