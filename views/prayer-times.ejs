<!DOCTYPE html>
<html lang="en">
<%- include('partials/head') %>
<body class="min-h-screen bg-slate-900">
  <%- include('partials/sidebar') %>
  
  <div class="lg:pl-64 min-h-screen">
    <header class="glass sticky top-0 z-30 border-b border-white/10">
      <div class="flex items-center justify-between px-4 py-4">
        <div class="flex items-center">
          <button onclick="toggleSidebar()" class="lg:hidden mr-4 text-slate-300 hover:text-white">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
          </button>
          <h1 class="text-2xl font-bold text-white">Prayer Times</h1>
        </div>
      </div>
    </header>
    
    <main class="p-4 lg:p-6">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4 lg:gap-6">
        <% prayerTimes.forEach((p, i) => { %>
          <div class="glass-card rounded-xl p-5 text-white border border-white/10 card-hover animate-slide-up" style="animation-delay: <%= i * 0.1 %>s">
            <div class="flex items-center mb-4">
              <div class="w-10 h-10 rounded-lg bg-amber-500/20 flex items-center justify-center mr-3 border border-amber-500/30">
                <svg class="w-5 h-5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
              <h3 class="text-xl font-bold text-white"><%= p.name %></h3>
            </div>
            <% if (canEdit) { %>
              <form action="/prayer-times" method="POST" class="space-y-3">
                <input type="hidden" name="id" value="<%= p.id %>">
                <div>
                  <label class="text-slate-400 text-xs block mb-1">Athaan</label>
                  <input type="time" name="adhan_time" value="<%= p.adhan_time %>" class="w-full bg-slate-800/50 border border-white/10 rounded-lg px-3 py-2 text-white focus:ring-2 focus:ring-amber-400 focus:border-amber-400">
                </div>
                <div>
                  <label class="text-slate-400 text-xs block mb-1">Iqamah</label>
                  <input type="time" name="iqamah_time" value="<%= p.iqamah_time %>" class="w-full bg-slate-800/50 border border-white/10 rounded-lg px-3 py-2 text-white focus:ring-2 focus:ring-amber-400 focus:border-amber-400">
                </div>
                <button type="submit" class="w-full bg-gradient-to-r from-amber-500 to-amber-600 hover:from-amber-600 hover:to-amber-700 text-slate-900 font-medium py-2 rounded-lg text-sm transition-all">Update</button>
              </form>
            <% } else { %>
              <div class="space-y-3">
                <div>
                  <p class="text-slate-400 text-xs">Athaan</p>
                  <p class="text-lg font-semibold text-white"><%= p.adhan_time %></p>
                </div>
                <div>
                  <p class="text-slate-400 text-xs">Iqamah</p>
                  <p class="text-3xl font-bold text-amber-400"><%= p.iqamah_time %></p>
                </div>
              </div>
            <% } %>
            <% if (p.updated_by_name) { %>
              <p class="text-slate-500 text-xs mt-4">Updated by <%= p.updated_by_name %></p>
            <% } %>
          </div>
        <% }) %>
      </div>
    </main>
  </div>
</body>
</html>